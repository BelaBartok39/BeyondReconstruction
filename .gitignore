# =============================================================================
# RF Anomaly Detection - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Datasets (large files - store on HuggingFace)
# -----------------------------------------------------------------------------
RED_DATA/
data/raw/
data/processed/
*.h5
*.hdf5
!data/examples/*.h5

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
pip-wheel-metadata/

# Virtual environments
venv/
.venv/
env/
ENV/

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.spyderproject
.spyproject

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Testing / Coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# -----------------------------------------------------------------------------
# Model Checkpoints
# -----------------------------------------------------------------------------
# Keep production model, ignore training intermediates
checkpoints/**/checkpoint_epoch_*.pt
checkpoints/**/latest_model.pt
# Uncomment to ignore all checkpoints except production:
# checkpoints/
# !checkpoints/snr_vae_hybrid_v1_*/best_model.pt
# !checkpoints/snr_vae_hybrid_v2_*/best_model.pt

# -----------------------------------------------------------------------------
# Logs and Outputs
# -----------------------------------------------------------------------------
*.log
logs/
wandb/
mlruns/
tensorboard_logs/

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Secrets and Credentials (safety)
# -----------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
secrets.yaml
credentials.json

# -----------------------------------------------------------------------------
# Cluster / HPC
# -----------------------------------------------------------------------------
slurm-*.out
*.slurm.out

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.pdf
*.bak
.claude/settings.local.json